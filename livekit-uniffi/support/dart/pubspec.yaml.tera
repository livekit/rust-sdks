name: {{ DART_PACKAGE_NAME }}
description: Dart bindings for the LiveKit UniFFI interface.
version: {{ CARGO_MAKE_CRATE_VERSION }}
publish_to: none

environment:
  sdk: ">=3.10.0 <4.0.0"

dependencies:
  ffi: ^2.1.0

dev_dependencies:
  # Native Assets build-hook support. `any` tracks the SDK-bundled versions.
  code_assets: any
  hooks: any
  test: ^1.25.0
